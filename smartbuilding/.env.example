# ---------- Public host/ports (local machine or EC2 public endpoint) ----------
BACKEND_HTTP_HOST=127.0.0.1
BACKEND_HTTP_PORT=8000
BACKEND_WS_HOST=127.0.0.1
BACKEND_WS_PORT=9502

RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_UI_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

MYSQL_PRIMARY_HOST=127.0.0.1
MYSQL_PRIMARY_PORT=3306
MYSQL_REPLICA_HOST=127.0.0.1
MYSQL_REPLICA_PORT=3307
MYSQL_DB=smartbuilding
MYSQL_USER=sb_user
MYSQL_PASSWORD=sb_password
MYSQL_ROOT_PASSWORD=root_password

# ---------- Internal docker network addresses (inside compose network) ----------
RABBITMQ_HOST_INTERNAL=rabbitmq
RABBITMQ_PORT_INTERNAL=5672
REDIS_HOST_INTERNAL=redis
REDIS_PORT_INTERNAL=6379
MYSQL_PRIMARY_HOST_INTERNAL=mysql-primary
MYSQL_PRIMARY_PORT_INTERNAL=3306
MYSQL_REPLICA_HOST_INTERNAL=mysql-replica
MYSQL_REPLICA_PORT_INTERNAL=3306
